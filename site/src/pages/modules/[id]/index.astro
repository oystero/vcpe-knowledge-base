---
import Layout from '../../../layouts/Layout.astro';
import { modules, getArticlesByModule, getTagCounts } from '../../../utils/content';
import { formatDate, readingTime, formatWordCount } from '../../../utils/markdown';

export function getStaticPaths() {
  return modules.map(m => ({
    params: { id: m.id },
  }));
}

const { id } = Astro.params;
const module = modules.find(m => m.id === id);
if (!module) return Astro.redirect('/');

const moduleArticles = getArticlesByModule(id);
const tagCounts = getTagCounts();

// Group articles by subfolder if any
const grouped: Record<string, typeof moduleArticles> = {};
for (const article of moduleArticles) {
  const parts = article.relativePath.split(/[/\\]/);
  const subfolder = parts.length > 2 ? parts[1] : 'default';
  if (!grouped[subfolder]) grouped[subfolder] = [];
  grouped[subfolder].push(article);
}
---

<Layout title={`${module.icon} ${module.name}`} activeModule={id}>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
    <a href="/" class="hover:text-accent-600 dark:hover:text-accent-400">首页</a>
    <span>/</span>
    <span class="text-gray-800 dark:text-gray-200">{module.name}</span>
  </nav>

  <!-- Module Header -->
  <div class="mb-8">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-4xl">{module.icon}</span>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">{module.name}</h1>
    </div>
    <p class="text-gray-600 dark:text-gray-400">{module.description}</p>
    <div class="mt-3 text-sm text-gray-500 dark:text-gray-400">
      共 {moduleArticles.length} 篇文章 · {formatWordCount(moduleArticles.reduce((sum, a) => sum + a.wordCount, 0))}
    </div>
  </div>

  <!-- Article List -->
  {Object.entries(grouped).map(([subfolder, arts]) => (
    <div class="mb-8">
      {subfolder !== 'default' && (
        <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-3 capitalize">{subfolder}</h2>
      )}
      <div class="space-y-3">
        {arts.map(article => (
          <a href={`/articles/${article.slug}/`} class="group flex items-start gap-4 bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm hover:shadow-md hover:border-accent-300 dark:hover:border-accent-600 transition-all duration-200">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                {article.type === 'case-study' && (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300">
                    案例
                  </span>
                )}
                {article.tags.slice(0, 3).map(tag => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-primary-800 text-gray-500 dark:text-gray-400">
                    {tag}
                  </span>
                ))}
              </div>
              <h3 class="font-semibold text-gray-800 dark:text-gray-200 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
                {article.title}
              </h3>
              {article.excerpt && (
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">{article.excerpt}</p>
              )}
              <div class="flex items-center gap-4 mt-2 text-xs text-gray-400 dark:text-gray-500">
                <span>{formatDate(article.updated || article.created)}</span>
                <span>{formatWordCount(article.wordCount)}</span>
                <span>约 {readingTime(article.wordCount)} 分钟阅读</span>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-accent-500 transition-colors flex-shrink-0 mt-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          </a>
        ))}
      </div>
    </div>
  ))}

  {moduleArticles.length === 0 && (
    <div class="text-center py-12 text-gray-500 dark:text-gray-400">
      <p class="text-4xl mb-4">📭</p>
      <p>该模块暂无文章</p>
    </div>
  )}
</Layout>
