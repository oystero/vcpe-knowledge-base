---
import Layout from '../../layouts/Layout.astro';
import { articles, getTagCounts } from '../../utils/content';
import { formatWordCount, readingTime, formatDate } from '../../utils/markdown';

const tagCounts = getTagCounts();
---

<Layout title="搜索" showSidebar={false}>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-6">🔍 搜索知识库</h1>

    <!-- Search Input -->
    <div class="relative mb-8">
      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
      </div>
      <input
        type="text"
        id="search-input"
        class="w-full pl-12 pr-4 py-3 rounded-xl border border-gray-300 dark:border-primary-700 bg-white dark:bg-primary-900 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-accent-500 focus:border-transparent outline-none text-lg"
        placeholder="输入关键词搜索文章标题、内容、标签..."
        autofocus
      />
    </div>

    <!-- Tag Filter -->
    <div class="mb-6">
      <h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 mb-3">按标签筛选</h3>
      <div class="flex flex-wrap gap-2" id="tag-filters">
        {tagCounts.slice(0, 20).map(({ tag, count }) => (
          <button
            data-tag={tag}
            class="tag-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-gray-200 dark:border-primary-700 text-sm text-gray-600 dark:text-gray-400 hover:border-accent-300 dark:hover:border-accent-600 hover:text-accent-600 dark:hover:text-accent-400 transition-all"
          >
            {tag}
            <span class="text-xs text-gray-400 dark:text-gray-500">({count})</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Results Count -->
    <div id="results-count" class="text-sm text-gray-500 dark:text-gray-400 mb-4 hidden">
      找到 <span id="count-num" class="font-semibold text-gray-700 dark:text-gray-300">0</span> 篇文章
    </div>

    <!-- Search Results -->
    <div id="search-results" class="space-y-3">
      <!-- Results will be populated by JS -->
    </div>

    <!-- Initial State -->
    <div id="initial-state" class="text-center py-12">
      <p class="text-4xl mb-4">🔎</p>
      <p class="text-gray-500 dark:text-gray-400">输入关键词开始搜索</p>
      <p class="text-sm text-gray-400 dark:text-gray-500 mt-2">支持搜索文章标题、内容摘要和标签</p>
    </div>
  </div>

  <script define:vars={{ articlesData: articles.map(a => ({
    id: a.id,
    title: a.title,
    excerpt: a.excerpt,
    slug: a.slug,
    module: a.module,
    moduleName: a.moduleName,
    tags: a.tags,
    wordCount: a.wordCount,
    created: a.created,
    updated: a.updated,
    content: a.content.slice(0, 2000),
  })) }}>
    import Fuse from 'fuse.js';

    const fuse = new Fuse(articlesData, {
      keys: [
        { name: 'title', weight: 0.4 },
        { name: 'tags', weight: 0.2 },
        { name: 'excerpt', weight: 0.2 },
        { name: 'content', weight: 0.2 },
      ],
      threshold: 0.4,
      includeScore: true,
      ignoreLocation: true,
      minMatchCharLength: 2,
    });

    const searchInput = document.getElementById('search-input');
    const resultsContainer = document.getElementById('search-results');
    const resultsCount = document.getElementById('results-count');
    const countNum = document.getElementById('count-num');
    const initialState = document.getElementById('initial-state');
    const tagButtons = document.querySelectorAll('.tag-btn');
    let activeTag = '';

    // Check URL params
    const urlParams = new URLSearchParams(window.location.search);
    const queryParam = urlParams.get('q');
    const tagParam = urlParams.get('tag');
    if (queryParam) {
      searchInput.value = queryParam;
      performSearch(queryParam);
    }
    if (tagParam) {
      activeTag = tagParam;
      document.querySelector(`[data-tag="${tagParam}"]`)?.classList.add('bg-accent-100', 'dark:bg-accent-900/30', 'border-accent-300', 'dark:border-accent-600', 'text-accent-700', 'dark:text-accent-300');
      performSearch(searchInput.value);
    }

    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      if (query.length === 0 && !activeTag) {
        resultsContainer.innerHTML = '';
        resultsCount.classList.add('hidden');
        initialState.classList.remove('hidden');
        return;
      }
      performSearch(query);
    });

    tagButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;
        if (activeTag === tag) {
          activeTag = '';
          btn.classList.remove('bg-accent-100', 'dark:bg-accent-900/30', 'border-accent-300', 'dark:border-accent-600', 'text-accent-700', 'dark:text-accent-300');
        } else {
          tagButtons.forEach(b => b.classList.remove('bg-accent-100', 'dark:bg-accent-900/30', 'border-accent-300', 'dark:border-accent-600', 'text-accent-700', 'dark:text-accent-300'));
          activeTag = tag;
          btn.classList.add('bg-accent-100', 'dark:bg-accent-900/30', 'border-accent-300', 'dark:border-accent-600', 'text-accent-700', 'dark:text-accent-300');
        }
        performSearch(searchInput.value.trim());
      });
    });

    function performSearch(query) {
      let results;

      if (query.length > 0) {
        results = fuse.search(query).map(r => r.item);
      } else {
        results = articlesData;
      }

      if (activeTag) {
        results = results.filter(r => r.tags.includes(activeTag));
      }

      initialState.classList.add('hidden');
      resultsCount.classList.remove('hidden');
      countNum.textContent = results.length;

      if (results.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-12">
            <p class="text-4xl mb-4">😕</p>
            <p class="text-gray-500 dark:text-gray-400">未找到匹配的文章</p>
            <p class="text-sm text-gray-400 dark:text-gray-500 mt-2">试试其他关键词或标签</p>
          </div>
        `;
        return;
      }

      function formatWC(count) {
        return count >= 10000 ? (count / 10000).toFixed(1) + '万字' : count + '字';
      }

      function formatDate(d) {
        if (!d) return '';
        try { return new Date(d).toLocaleDateString('zh-CN'); } catch { return d; }
      }

      resultsContainer.innerHTML = results.map(r => `
        <a href="/articles/${r.slug}/" class="group flex items-start gap-4 bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm hover:shadow-md hover:border-accent-300 dark:hover:border-accent-600 transition-all duration-200">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="text-xs px-2 py-0.5 rounded-full bg-accent-100 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300">${r.moduleName}</span>
              ${r.tags.slice(0, 3).map(t => `<span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-primary-800 text-gray-500 dark:text-gray-400">${t}</span>`).join('')}
            </div>
            <h3 class="font-semibold text-gray-800 dark:text-gray-200 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">${r.title}</h3>
            ${r.excerpt ? `<p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">${r.excerpt}</p>` : ''}
            <div class="flex items-center gap-4 mt-2 text-xs text-gray-400 dark:text-gray-500">
              <span>${formatDate(r.updated || r.created)}</span>
              <span>${formatWC(r.wordCount)}</span>
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-accent-500 transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      `).join('');
    }
  </script>
</Layout>
