---
import Layout from '../layouts/Layout.astro';
---

<Layout title="页面未找到" showSidebar={false}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <div class="text-8xl mb-6">📭</div>
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">404</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">抱歉，您访问的页面不存在</p>
    <a href="/" class="px-6 py-3 bg-accent-600 hover:bg-accent-700 text-white rounded-lg transition-colors font-medium">
      返回首页
    </a>
  </div>
</Layout>
