---
import Layout from '../layouts/Layout.astro';
import { modules, getStats, getTagCounts, articles } from '../utils/content';
import { formatDate, readingTime, formatWordCount } from '../utils/markdown';

const stats = getStats();
const tagCounts = getTagCounts().slice(0, 15);
const base = import.meta.env.BASE_URL;

// Recent articles
const recentArticles = [...articles]
  .sort((a, b) => (b.updated || b.created).localeCompare(a.updated || a.created))
  .slice(0, 8);
---

<Layout title="首页" showSidebar={true}>
  <!-- Hero Section -->
  <div class="mb-10">
    <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
      💰 VC/PE 投资知识库
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">
      面向投资实战的系统化知识框架。不是行业百科，而是回答：<strong class="text-gray-800 dark:text-gray-200">"这对投资决策意味着什么？"</strong>
    </p>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm">
        <div class="text-2xl font-bold text-accent-600 dark:text-accent-400">{stats.totalArticles}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">篇文章</div>
      </div>
      <div class="bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm">
        <div class="text-2xl font-bold text-accent-600 dark:text-accent-400">{stats.totalModules}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">个模块</div>
      </div>
      <div class="bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm">
        <div class="text-2xl font-bold text-accent-600 dark:text-accent-400">{formatWordCount(stats.totalWords)}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">总字数</div>
      </div>
      <div class="bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm">
        <div class="text-2xl font-bold text-accent-600 dark:text-accent-400">{stats.totalTags}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400">个标签</div>
      </div>
    </div>
  </div>

  <!-- Module Grid -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">📚 知识模块</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {modules.map(m => (
        <a href={`${base}modules/${m.id}/`} class="group bg-white dark:bg-primary-900 rounded-xl p-5 border border-gray-200 dark:border-primary-800 shadow-sm hover:shadow-md hover:border-accent-300 dark:hover:border-accent-600 transition-all duration-200">
          <div class="flex items-start gap-3">
            <span class="text-2xl">{m.icon}</span>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-800 dark:text-gray-200 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors">
                {m.name}
              </h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{m.description}</p>
              <div class="mt-2 text-xs text-gray-400 dark:text-gray-500">{m.count} 篇文章</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Recent Articles -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">🕐 最近更新</h2>
    <div class="space-y-3">
      {recentArticles.map(article => (
        <a href={`${base}articles/${article.slug}/`} class="group flex items-start gap-4 bg-white dark:bg-primary-900 rounded-xl p-4 border border-gray-200 dark:border-primary-800 shadow-sm hover:shadow-md hover:border-accent-300 dark:hover:border-accent-600 transition-all duration-200">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs px-2 py-0.5 rounded-full bg-accent-100 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300">
                {article.moduleName}
              </span>
              {article.type === 'case-study' && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300">
                  案例
                </span>
              )}
            </div>
            <h3 class="font-semibold text-gray-800 dark:text-gray-200 group-hover:text-accent-600 dark:group-hover:text-accent-400 transition-colors truncate">
              {article.title}
            </h3>
            {article.excerpt && (
              <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">{article.excerpt}</p>
            )}
            <div class="flex items-center gap-4 mt-2 text-xs text-gray-400 dark:text-gray-500">
              <span>{formatDate(article.updated || article.created)}</span>
              <span>{formatWordCount(article.wordCount)}</span>
              <span>约 {readingTime(article.wordCount)} 分钟</span>
            </div>
          </div>
          <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-accent-500 transition-colors flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
        </a>
      ))}
    </div>
  </section>

  <!-- Tags Cloud -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">🏷️ 热门标签</h2>
    <div class="flex flex-wrap gap-2">
      {tagCounts.map(({ tag, count }) => (
        <a href={`${base}search/?tag=${encodeURIComponent(tag)}`} class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full bg-white dark:bg-primary-900 border border-gray-200 dark:border-primary-800 text-sm text-gray-600 dark:text-gray-400 hover:border-accent-300 dark:hover:border-accent-600 hover:text-accent-600 dark:hover:text-accent-400 transition-all">
          <span>{tag}</span>
          <span class="text-xs text-gray-400 dark:text-gray-500">({count})</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Learning Paths -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-gray-200 mb-6">🗺️ 学习路径</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 dark:from-blue-900/20 dark:to-blue-800/20 rounded-xl p-5 border border-blue-200 dark:border-blue-800">
        <h3 class="font-semibold text-blue-800 dark:text-blue-300 mb-2">🎯 新手入门路径</h3>
        <ol class="text-sm text-blue-700 dark:text-blue-400 space-y-1 list-decimal list-inside">
          <li>LP与GP关系 → 基金生命周期 → 管理费与收益分配</li>
          <li>项目来源与筛选 → 尽职调查框架 → 投资决策流程</li>
          <li>投资条款清单 → 对赌协议 → 反稀释条款</li>
        </ol>
      </div>
      <div class="bg-gradient-to-br from-green-50 to-green-100 dark:from-green-900/20 dark:to-green-800/20 rounded-xl p-5 border border-green-200 dark:border-green-800">
        <h3 class="font-semibold text-green-800 dark:text-green-300 mb-2">📊 估值学习路径</h3>
        <ol class="text-sm text-green-700 dark:text-green-400 space-y-1 list-decimal list-inside">
          <li>Pre-Money与Post-Money → 现金流折现法 → 可比公司法</li>
          <li>风险投资法 → 估值谈判与博弈</li>
        </ol>
      </div>
      <div class="bg-gradient-to-br from-purple-50 to-purple-100 dark:from-purple-900/20 dark:to-purple-800/20 rounded-xl p-5 border border-purple-200 dark:border-purple-800">
        <h3 class="font-semibold text-purple-800 dark:text-purple-300 mb-2">📜 法律条款路径</h3>
        <ol class="text-sm text-purple-700 dark:text-purple-400 space-y-1 list-decimal list-inside">
          <li>股东协议核心条款 → 对赌协议 → 反稀释条款</li>
          <li>优先清算权 → 董事会席位与一票否决</li>
        </ol>
      </div>
      <div class="bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-900/20 dark:to-amber-800/20 rounded-xl p-5 border border-amber-200 dark:border-amber-800">
        <h3 class="font-semibold text-amber-800 dark:text-amber-300 mb-2">📖 案例学习路径</h3>
        <ol class="text-sm text-amber-700 dark:text-amber-400 space-y-1 list-decimal list-inside">
          <li>成功：字节跳动 → 美团 → 拼多多</li>
          <li>失败：OFO → 瑞幸咖啡 → 乐视</li>
        </ol>
      </div>
    </div>
  </section>
</Layout>
